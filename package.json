{
  "name": "maire-rufisque-est",
  "version": "1.0.0",
  "description": "Plateforme SaaS pour la Mairie de Rufisque-Est (et autres communes du Sénégal) — Frontend assets",
  "private": true,
  "scripts": {
    "dev": "tailwindcss -i ./src/css/input.css -o ./assets/css/tailwind.css --watch",
    "build": "tailwindcss -i ./src/css/input.css -o ./assets/css/tailwind.css --minify",
    "build:dev": "tailwindcss -i ./src/css/input.css -o ./assets/css/tailwind.css"
  },
  "devDependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "leaflet": "^1.9.4",
    "tailwindcss": "^3.4.17"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
