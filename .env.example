# =====================================================================
#  Mairie de Rufisque-Est — Variables d'environnement (.env)
#  -------------------------------------------------------------------
#  1) Copier ce fichier en `.env` à la racine du projet
#  2) Remplir les valeurs ci-dessous (NE JAMAIS commit le .env)
#  3) Le loader (includes/env-loader.php) lit automatiquement .env
#     et expose les variables via getenv() + constantes MAIRE_*
# =====================================================================

# ── Environnement ──────────────────────────────────────────────────────
# development | staging | production | testing
# En 'development' les comptes de démonstration sont auto-créés ;
# en 'production' aucun compte démo n'est créé.
APP_ENV=production

# ── Logger ─────────────────────────────────────────────────────────────
# debug | info | notice | warning | error | critical
MAIRE_LOG_LEVEL=info

# =====================================================================
#  BASE DE DONNÉES
# =====================================================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mairie_senegal
DB_USER=root
DB_PASS=

# =====================================================================
#  PAIEMENT MOBILE MONEY
# =====================================================================
# Provider par défaut sélectionné dans le formulaire de paiement.
# Valeurs : log | wave | orange_money | free_money
PAIEMENT_PROVIDER_DEFAUT=log

# Secret partagé pour valider les webhooks de paiement entrants.
# Générer avec : openssl rand -hex 32
PAIEMENT_WEBHOOK_SECRET=

# ─── Wave ────────────────────────────────────────────────────────────
# Documentation : https://docs.wave.com/business/api/v1/
# 1) Créer un compte sur https://business.wave.com
# 2) Settings → API Keys → "Generate new key"
# 3) Copier la clé (commence par "wave_sn_prod_" en production)
WAVE_API_KEY=
WAVE_WEBHOOK_SECRET=
# Endpoint par défaut : https://api.wave.com/v1/checkout/sessions
WAVE_API_ENDPOINT=https://api.wave.com/v1/checkout/sessions

# ─── Orange Money Sénégal ────────────────────────────────────────────
# Documentation : https://developer.orange.com/apis/om-webpay
# 1) Créer un compte sur https://developer.orange.com
# 2) S'abonner à l'API "Orange Money Web Payment"
# 3) Demander un compte marchand auprès d'Orange Sénégal Business
# 4) Récupérer :
#    - MERCHANT_KEY (clé du compte marchand)
#    - CLIENT_ID + CLIENT_SECRET (OAuth Orange)
#    - AUTH_HEADER = base64(CLIENT_ID:CLIENT_SECRET)
ORANGE_MONEY_MERCHANT_KEY=
ORANGE_MONEY_CLIENT_ID=
ORANGE_MONEY_CLIENT_SECRET=
ORANGE_MONEY_AUTH_HEADER=
# Sandbox  : https://api.orange.com/orange-money-webpay/dev/v1/webpayment
# Prod     : https://api.orange.com/orange-money-webpay/prod/v1/webpayment
ORANGE_MONEY_ENDPOINT=https://api.orange.com/orange-money-webpay/prod/v1/webpayment

# ─── Free Money (Free Sénégal / ex-Tigo Cash) ─────────────────────────
# Pas d'API publique : nécessite un contrat marchand B2B avec Free.
# Contact commercial : business@free.sn
# Free fournit ensuite endpoint + clés HMAC.
FREE_MONEY_API_KEY=
FREE_MONEY_API_SECRET=
FREE_MONEY_ENDPOINT=

# =====================================================================
#  SMS (notifications citoyens)
# =====================================================================
# Provider : log | orange | twilio | wari
# 'log' écrit dans logs/sms-outbox.log (idéal en dev/préprod sans budget SMS)
SMS_PROVIDER=log
SMS_API_KEY=
SMS_API_SECRET=
# Pour Orange SN : senderAddress format "tel:+221XXXXXXXXX"
# Pour Twilio    : numéro Twilio (ex. +14155551234)
SMS_SENDER_ID=MAIRIE-RFQE

# =====================================================================
#  EMAIL (SMTP authentifié)
# =====================================================================
# Le code utilise un mailer SMTP pur PHP (stream sockets, sans PHPMailer).
# Si MAIL_HOST/USERNAME/PASSWORD sont vides → fallback sur mail() natif.
#
# ── Gmail (recommandé pour démarrer rapidement) ──
# 1) Activer la double authentification sur le compte Gmail
# 2) Aller sur https://myaccount.google.com/apppasswords
# 3) Générer un "mot de passe d'application" (16 caractères)
# 4) Coller ce mot de passe (PAS le mot de passe normal Gmail !)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=Rufisquest02@gmail.com
MAIL_PASSWORD=
MAIL_FROM_NAME="Mairie de Rufisque-Est"
MAIL_FROM_EMAIL=Rufisquest02@gmail.com
# 'tls' (STARTTLS sur 587 — Gmail/Outlook) | 'ssl' (port 465 direct) | 'none'
MAIL_ENCRYPTION=tls

# ── Alternatives SMTP recommandées en production ──
# • Brevo (ex-Sendinblue) : 300 emails/jour gratuits, smtp-relay.brevo.com:587
# • Mailgun              : 5 000/mois gratuits, smtp.mailgun.org:587
# • Amazon SES           : très bon prix, email-smtp.eu-west-1.amazonaws.com:587
# • OVH Hébergement      : ssl0.ovh.net:587 (compte mail OVH classique)

# =====================================================================
#  CHATBOT (assistant IA optionnel)
# =====================================================================
CHATBOT_OPENAI_KEY=
CHATBOT_MODEL=gpt-4o-mini

# =====================================================================
#  SUPER-ADMIN (éditeur de la plateforme)
# =====================================================================
# Liste blanche d'IPs autorisées à accéder à /super-admin (séparées par ,)
# Formats supportés :
#   - IP exacte IPv4  : 88.123.45.67
#   - IP exacte IPv6  : 2001:db8::1
#   - Plage CIDR IPv4 : 192.168.1.0/24, 41.219.0.0/16
#   - Plage CIDR IPv6 : 2001:db8::/32
# Exemple : SUPER_ADMIN_ALLOWED_IPS=127.0.0.1, ::1, 41.219.184.0/22
# Laisser vide pour autoriser depuis n'importe quelle IP (déconseillé en prod)
SUPER_ADMIN_ALLOWED_IPS=

# Proxys de confiance (IPs derrière lesquels REMOTE_ADDR est ton load-balancer/CDN)
# Permet de lire X-Forwarded-For SEULEMENT depuis ces IPs. Exemple Cloudflare :
# TRUSTED_PROXIES=173.245.48.0/20, 103.21.244.0/22
TRUSTED_PROXIES=
